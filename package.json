{
  "name": "figma-react-forge",
  "version": "0.1.0",
  "description": "Convert Figma REST JSON or exported node JSON into React components, CSS, and design tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "figma-react-forge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "audit": "npm audit --audit-level=moderate",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "outdated": "npm outdated --long",
    "public-surface": "node scripts/check-public-surface.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "keywords": [
    "figma",
    "react",
    "design-tokens",
    "typescript",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.39.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
